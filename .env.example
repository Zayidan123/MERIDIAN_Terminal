# ──────────────────────────────────────────────────────────────────────────
# MERIDIAN Terminal — Environment Configuration Template
# ──────────────────────────────────────────────────────────────────────────
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# See PRD §16.2 (Secrets Management) — all keys must be trade-only where
# applicable, IP-whitelisted, and rotated periodically.

# ── Database ───────────────────────────────────────────────────────────────
DATABASE_URL=file:/home/z/my-project/db/custom.db

# ── Auth (single-user) ────────────────────────────────────────────────────
# CHANGE the password before any production use.
MERIDIAN_ADMIN_EMAIL=admin@meridian.local
MERIDIAN_ADMIN_PASSWORD=change-me-to-a-strong-password
# Optional pre-hashed bcrypt (leave empty to auto-hash MERIDIAN_ADMIN_PASSWORD):
MERIDIAN_ADMIN_PASSWORD_HASH=
# Optional TOTP — set to a base32 secret to require 2FA on login
# (generate via the /api/auth/totp-setup endpoint or `otplib`):
MERIDIAN_TOTP_SECRET=
NEXT_PUBLIC_TOTP_ENABLED=0
NEXT_PUBLIC_ADMIN_EMAIL=admin@meridian.local
# NextAuth — generate a strong random string (>= 32 chars):
NEXTAUTH_SECRET=generate-a-strong-random-secret-here
NEXTAUTH_URL=http://localhost:3000

# ── Telegram Bot notifications (PRD FR-2.3) ──────────────────────────────
# Get token from @BotFather, chat ID from @userinfobot.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Fase 4 Execution Bot (PRD §8.5) ───────────────────────────────────────
# Leave empty to stay in PAPER mode. CRITICAL: use a TRADE-ONLY API key
# with WITHDRAWAL DISABLED on the exchange, and IP-whitelist it (PRD §16.7).
EXCHANGE_API_KEY=
EXCHANGE_API_SECRET=
EXCHANGE_NAME=binance
# Optional shared secret to protect the execution-bot mini-service API
# (port 3002). If set, all bot routes require `Authorization: Bearer <token>`.
BOT_API_TOKEN=
