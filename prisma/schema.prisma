// MERIDIAN Terminal — Prisma schema (PRD §14)
// SQLite for local-first dev. All market data is fetched live from real
// sources (Binance, Yahoo Finance, etc.) — NO simulated/dummy data is ever
// persisted as if it were market data.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// Master list of tradeable instruments across asset classes.
model Instrument {
  id         String   @id @default(cuid())
  assetClass String   // "CRYPTO" | "EQUITY" | "FOREX" | "COMMODITY"
  ticker     String   @unique // e.g. "BTCUSDT", "BBCA.JK", "EURUSD=X", "GC=F"
  symbol     String   // display symbol e.g. "BTC/USDT", "BBCA", "EUR/USD", "XAU/USD"
  name       String   // human readable name
  exchange   String?  // e.g. "BINANCE", "IDX", "CCY", "COMEX"
  currency   String   // quote currency e.g. "USDT","IDR","USD"
  source     String   // primary data source key e.g. "binance","yahoo"
  lotSize    Float?   // contract / lot size hint
  metadata   String?  // JSON string of extra info
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  watchlistItems     WatchlistItem[]
  alerts             Alert[]
  positions          Position[]
  signalEvents       SignalEvent[]
  fundamentals       Fundamental[]
  candles            PriceOhlcv[]
}

/// Persisted OHLCV candles (PRD §14 `price_ohlcv`).
/// Populated as the data layer fetches live candles from real sources —
/// enables local historical queries / backtesting without re-hitting APIs.
model PriceOhlcv {
  // Composite key: one row per (instrument, timeframe, timestamp).
  // SQLite doesn't support multi-column @id well with @default, so we use a
  // synthetic cuid id + a unique compound index.
  id           String   @id @default(cuid())
  instrumentId String
  timeframe    String   // "15m" | "1h" | "4h" | "1d" (the interval the candle represents)
  timestamp    Int      // epoch ms (candle open time)
  open         Float
  high         Float
  low          Float
  close        Float
  volume       Float
  source       String   // "binance" | "yahoo"
  fetchedAt    DateTime @default(now())

  instrument Instrument @relation(fields: [instrumentId], references: [id], onDelete: Cascade)

  @@unique([instrumentId, timeframe, timestamp])
  @@index([instrumentId, timeframe, timestamp])
  @@index([instrumentId, timestamp])
}

/// Cached fundamental snapshot for an instrument.
/// Equity fields come from Yahoo Finance (quoteSummary); crypto fields come
/// from CoinGecko (coins/{id}). Equity-only fields are null for crypto rows
/// and vice versa.
model Fundamental {
  id        String   @id @default(cuid())
  ticker    String   @unique
  period    String?  // e.g. "FY2024" or "2024-Q4"
  revenue   Float?
  netIncome Float?
  eps       Float?
  roe       Float?   // %
  per       Float?
  pbv       Float?
  graham    Float?   // Graham number
  dcfFair   Float?   // simple DCF fair value
  // Crypto (CoinGecko)
  marketCap         Float? // USD
  fdv               Float? // fully diluted valuation, USD
  circulatingSupply Float?
  totalSupply       Float?
  maxSupply         Float?
  source    String
  fetchedAt DateTime @default(now())

  instrument Instrument @relation(fields: [ticker], references: [ticker])
}

/// A watchlist groups instruments the user is actively monitoring.
model Watchlist {
  id        String   @id @default(cuid())
  name      String   @default("Default")
  createdAt DateTime @default(now())

  items WatchlistItem[]
}

model WatchlistItem {
  id           String   @id @default(cuid())
  watchlistId  String
  instrumentId String
  addedAt      DateTime @default(now())

  watchlist  Watchlist  @relation(fields: [watchlistId], references: [id], onDelete: Cascade)
  instrument Instrument @relation(fields: [instrumentId], references: [id], onDelete: Cascade)

  @@unique([watchlistId, instrumentId])
}

/// User-defined alert conditions (PRD FR-2.1).
model Alert {
  id           String    @id @default(cuid())
  instrumentId String
  metric       String    // "price" | "pct_change_24h" | "volume_spike" | "rsi" | "price_above_ma"
  operator     String    // "gt" | "lt" | "cross_up" | "cross_down"
  threshold    Float
  status       String    @default("ACTIVE") // "ACTIVE" | "TRIGGERED" | "PAUSED" | "DELETED"
  note         String?
  createdAt    DateTime  @default(now())
  triggeredAt  DateTime?
  updatedAt    DateTime  @updatedAt

  instrument Instrument @relation(fields: [instrumentId], references: [id], onDelete: Cascade)

  @@index([status])
}

/// A signal/anomaly event detected by the engine (PRD FR-2.2, FR-2.4).
model SignalEvent {
  id           String   @id @default(cuid())
  instrumentId String
  signalType   String   // "VOLUME_SPIKE" | "BREAKOUT" | "RSI_OB" | "RSI_OS" | "ALERT_TRIGGER" | "ANOMALY"
  severity     String   @default("INFO") // "INFO" | "WARN" | "CRITICAL"
  message      String
  contextJson  String   // JSON: the data that triggered it
  priceAtEvent Float?
  createdAt    DateTime @default(now())

  instrument Instrument @relation(fields: [instrumentId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([signalType])
}

/// A manually entered portfolio position (PRD FR-3.1).
model Position {
  id           String   @id @default(cuid())
  instrumentId String
  side         String   @default("LONG") // "LONG" | "SHORT"
  entryPrice   Float
  size         Float    // quantity
  openedAt     DateTime @default(now())
  note         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  instrument Instrument @relation(fields: [instrumentId], references: [id], onDelete: Cascade)
}

/// Periodic risk snapshot for the portfolio (PRD §14 risk_snapshots).
model RiskSnapshot {
  id              String   @id @default(cuid())
  totalEquity     Float
  totalExposure   Float
  exposurePct     Float
  varEstimate     Float?   // value at risk
  maxDrawdown     Float?
  currentDrawdown Float?
  createdAt       DateTime @default(now())
}

/// Execution bot configuration + state (PRD Fase 4).
model BotConfig {
  id           String   @id @default("singleton")
  mode         String   @default("PAPER") // "PAPER" | "LIVE"
  killSwitch   Boolean  @default(false)   // manual kill-switch
  autoKillDd   Float    @default(20)      // auto kill-switch daily drawdown %
  maxOrderUsd  Float    @default(500)     // hard cap per order (USD notional)
  maxDailyUsd  Float    @default(2000)    // hard cap per day (USD notional)
  updatedAt    DateTime @updatedAt
}

/// Orders — paper & live (PRD FR-4.5, §14 `orders`).
model Order {
  id            String    @id @default(cuid())
  instrumentId  String
  side          String    // "BUY" | "SELL"
  type          String    // "MARKET" | "LIMIT"
  size          Float     // quantity
  price         Float?    // limit price (null for market)
  avgFillPrice  Float?    // executed avg price
  status        String    @default("PENDING") // "PENDING"|"FILLED"|"PARTIAL"|"CANCELLED"|"REJECTED"
  mode          String    @default("PAPER")    // "PAPER" | "LIVE"
  exchange      String?   // "binance" etc.
  exchangeOrderId String? // broker/exchange order id (live only)
  reason        String?   // rejection reason
  valueUsd      Float     // notional USD (for cap checks)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  executedAt    DateTime?

  @@index([status])
  @@index([createdAt])
  @@index([mode])
}

/// Tamper-evident audit log for every bot action (PRD §16.10).
model AuditLog {
  id        String   @id @default(cuid())
  action    String   // "ORDER_PLACED"|"ORDER_CANCELLED"|"ORDER_FILLED"|"KILL_SWITCH_ON"|"KILL_SWITCH_OFF"|"MODE_CHANGE"|"CAP_BREACH"|"ANOMALY"
  message   String
  contextJson String? // JSON details
  severity  String   @default("INFO") // "INFO" | "WARN" | "CRITICAL"
  // Hash-chain field for tamper-evidence: hash of (prevHash + this row's canonical content).
  // First row's prevHash = "genesis".
  prevHash  String
  hash      String
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([action])
}

/// Provenance / health log for every external data request (PRD FR-0.5).
model DataSourceHealthLog {
  id           String   @id @default(cuid())
  source       String   // "binance" | "yahoo" | "coingecko"
  endpoint     String   // short label of endpoint
  status       String   // "OK" | "FAIL" | "RATE_LIMITED" | "TIMEOUT"
  latencyMs    Int?
  errorMessage String?
  createdAt    DateTime @default(now())

  @@index([source, createdAt])
  @@index([status])
}
